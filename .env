# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# --- Database (Neon Postgres) ---
# Thay the link Neon DB cua ban vao day
# DATABASE_URL: pooled connection (used at runtime) — use Neon's *pooled*
#   connection string (host has "-pooler" in it, via PgBouncer) so a burst of
#   concurrent requests can't exhaust Postgres' direct connection limit.
# DIRECT_URL: direct connection (used by `prisma db push` / migrations only)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"
DIRECT_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# --- NextAuth (Auth.js) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Optional: GitHub OAuth provider ---
# Leave blank to only use email/password (Credentials) login.
# Create an OAuth app at https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""

# --- Optional: Upstash Redis (shared rate limiting) ---
# Without these, rate limiting falls back to an in-memory store that only
# protects a single server instance. For real protection in production
# (multiple serverless instances / servers behind a load balancer), create a
# free Redis database at https://console.upstash.com and paste its REST
# credentials here.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
